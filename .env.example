# ---------------------------------------------------------------------------
# 237Sentinel API — environment template. Copy to .env and fill in.
# Nothing here is a secret in the example. Never commit a real .env.
# ---------------------------------------------------------------------------

# --- Core ---
APP_ENV=development                 # development | production
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins. Include your Firebase domain in prod.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database ---
# Postgres (Supabase/Neon) in production. Falls back to local SQLite if unset,
# so the app still boots for a first run without a database configured.
DATABASE_URL=

# --- LLM chain (semantic layer) ---
# Comma-separated fallback chain, tried left to right. Recognised providers:
#   gemini | hf_router | anthropic | none
# When all fail, the layer falls back to deterministic rules. Keys stay
# server-side and are NEVER shipped to the browser.
LLM_PROVIDER=gemini,hf_router
LLM_MODEL=gemini-2.0-flash          # the Gemini model id
GEMINI_API_KEY=                     # Google AI Studio key (aistudio.google.com/apikey)
# The HF router reuses HF_API_KEY below. Override the models if you like:
# HF_ROUTER_TEXT_MODEL=meta-llama/Llama-3.3-70B-Instruct
# HF_ROUTER_VISION_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=                    # for OpenAI-compatible endpoints
HF_API_KEY=                         # for provider=hf (HF Inference API)

# --- Model inference mode ---
# local  -> load transformers/torch models in-process (needs a big host)
# hf_api -> call the models hosted on Hugging Face over HTTPS (light host like
#           Render free tier; no torch shipped). Requires HF_API_KEY below.
INFERENCE_MODE=local
# HF token with "Inference Providers" permission (hf.co/settings/tokens).
HF_API_KEY=

# Re-seed the registry on startup (for ephemeral hosts like Render + SQLite).
SEED_ON_STARTUP=false

# --- Hugging Face model cache (optional; local mode only) ---
HF_HOME=./hf_cache
# If a model is gated/needs a token to download at build time.
HF_TOKEN=

# --- Optional external signals (degrade silently if absent) ---
GOOGLE_SAFE_BROWSING_KEY=

# --- Rate limiting (free citizen tier) ---
RATE_LIMIT_PER_HOUR=20
RATE_LIMIT_VIDEO_PER_HOUR=5

# --- Media retention ---
STORE_MEDIA=false                   # default off; store only with consent
MEDIA_RETENTION_DAYS=30

# --- Admin ---
# Set a strong random value to enable the /api/v1/admin moderation endpoints.
ADMIN_TOKEN=

# --- Telegram bot (optional; hosted as a webhook in this service) ---
TELEGRAM_BOT_TOKEN=
# Optional shared secret; if set, it must match the setWebhook secret_token.
TELEGRAM_WEBHOOK_SECRET=

# --- WhatsApp (scaffolded, disabled by default) ---
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
